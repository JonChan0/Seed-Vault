# OS
.DS_Store
Thumbs.db
desktop.ini

# Obsidian
.obsidian/workspace.json
.obsidian/workspace-mobile.json
.obsidian/plugins/
.obsidian/themes/
.obsidian/snippets/

# Raw sources — often large or sensitive; opt-in per wiki instance
# Uncomment to track raw sources in git:
# !raw/*.md
raw/
!raw/.gitkeep

# Wiki content — opt-in per wiki instance
# The template ships empty; each wiki's content stays local unless you want it tracked
wiki/concepts/
wiki/sources/
wiki/topics/
!wiki/concepts/.gitkeep
!wiki/sources/.gitkeep
!wiki/topics/.gitkeep
!wiki/_index.md
!wiki/_catalog.md

# Outputs and visualizations — ephemeral, not tracked
outputs/
!outputs/.gitkeep
viz/
!viz/.gitkeep

# Python / Node artifacts if any tooling is added later
__pycache__/
*.pyc
node_modules/
