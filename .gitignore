# OS
.DS_Store
Thumbs.db
desktop.ini

# Obsidian
.obsidian/workspace.json
.obsidian/workspace-mobile.json
.obsidian/plugins/
.obsidian/themes/
.obsidian/snippets/

# Claude Code — project-local settings and generated skill links
# Skills are already tracked in _vault/vault-*/SKILL.md — no need to track the links too
.claude/skills/
.claude/settings.local.json
.claude/todos.json

# Gemini CLI — project-local settings and generated skill links
# Skills are already tracked in _vault/vault-*/SKILL.md — no need to track the links too
.gemini/skills/

# Raw sources — often large or sensitive; opt-in per wiki instance
# Uncomment to track raw sources in git:
# !raw/*.md
raw/
!raw/.gitkeep

# Wiki content — local only, never tracked
# All wiki/ files are generated locally by the LLM and deterministic engines.
# Tracking them would cause merge conflicts when pulling framework updates.
# install.sh creates wiki/_index.md on first run if it doesn't exist.
wiki/

# Outputs and visualizations — ephemeral, not tracked
outputs/
!outputs/.gitkeep
viz/
!viz/.gitkeep

# Python
__pycache__/
*.pyc
.venv/

# Node
node_modules/

# uv lock file — track it for reproducible builds
# uv.lock is auto-generated by uv sync

.trash

#Syncthing folders
.st*
