# OS
.DS_Store
Thumbs.db
desktop.ini

# Obsidian
.obsidian/workspace.json
.obsidian/workspace-mobile.json
.obsidian/plugins/
.obsidian/themes/
.obsidian/snippets/

# Claude Code — project-local settings (user-specific, not tracked)
# .claude/skills/ IS tracked — relative symlinks to _vault/vault-*/SKILL.md
.claude/settings.local.json
.claude/todos.json

# Gemini CLI skills directory — hard-linked from _vault/vault-*/SKILL.md by install.sh
# Content is already tracked in _vault/; this directory is derived
# Leading / anchors the pattern to the repo root so .claude/skills/ is unaffected
/skills/

# Raw sources — often large or sensitive; opt-in per wiki instance
# Uncomment to track raw sources in git:
# !raw/*.md
raw/
!raw/.gitkeep

# Wiki content — opt-in per wiki instance
# The template ships empty; each wiki's content stays local unless you want it tracked
wiki/concepts/
wiki/sources/
wiki/topics/
!wiki/concepts/.gitkeep
!wiki/sources/.gitkeep
!wiki/topics/.gitkeep
!wiki/_index.md
!wiki/_log.md
!wiki/_migration-log.md

# Outputs and visualizations — ephemeral, not tracked
outputs/
!outputs/.gitkeep
viz/
!viz/.gitkeep

# Python
__pycache__/
*.pyc
.venv/

# Node
node_modules/

# uv lock file — track it for reproducible builds
# uv.lock is auto-generated by uv sync

.trash

#Syncthing folders
.st*
